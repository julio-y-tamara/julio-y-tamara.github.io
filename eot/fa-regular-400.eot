<script>
document.addEventListener("DOMContentLoaded", function() {
  const elementos = document.querySelectorAll(".zoom-animar");
  
  const observer = new IntersectionObserver(entries => {
    entries.forEach(entry => {
      if (entry.isIntersecting) {
        entry.target.classList.add("zoom-in");
        entry.target.classList.remove("zoom-out");
      } else {
        entry.target.classList.remove("zoom-in");
        entry.target.classList.add("zoom-out");
      }
    });
  }, { threshold: 0.25 });

  elementos.forEach(el => observer.observe(el));
});
</script>

<script>
(function() {
    const activarPantallaCompleta = () => {
        const docElm = document.documentElement;
        const request = docElm.requestFullscreen || 
                        docElm.webkitRequestFullscreen || 
                        docElm.msRequestFullscreen || 
                        docElm.mozRequestFullScreen;

        if (request) {
            request.call(docElm).catch(err => {
                console.log(`Error al intentar modo pantalla completa: ${err.message}`);
            });
        }
    };

    const boton = document.getElementById("btnIngresar");
    if (boton) {
        boton.addEventListener("click", activarPantallaCompleta);
    }
})();
</script>
<script>
document.addEventListener("DOMContentLoaded", function () {
    const btnEntrar = document.getElementById("btnIngresar");
    const secciones = document.querySelectorAll(".seccion-invitacion");
    const musica = document.getElementById("musica");
    const botonFlotante = document.getElementById("botonMusica");

    // 1. Ocultar secciones al cargar
    secciones.forEach(sec => sec.style.display = "none");

    // 2. Acción al hacer Click en "Ingresar"
    if (btnEntrar) {
        btnEntrar.addEventListener("click", function () {
            // Ocultar la portada (sección actual del botón)
            const portada = btnEntrar.closest(".elementor-section, .e-con");
            if (portada) portada.style.display = "none";
            
            // Mostrar contenido y botón de música
            secciones.forEach(sec => sec.style.display = "block");
            if (botonFlotante) botonFlotante.style.display = "flex";
            
            // Play Música
            if (musica) {
                musica.play().catch(err => console.log("El navegador bloqueó el auto-play inicial"));
            }
        });
    }

    // 3. Control de Play/Pause del botón flotante
    if (botonFlotante && musica) {
        botonFlotante.addEventListener("click", function () {
            if (musica.paused) {
                musica.play();
                botonFlotante.classList.remove("paused");
            } else {
                musica.pause();
                botonFlotante.classList.add("paused");
            }
        });
    }
});
</script>
<script>
document.addEventListener('DOMContentLoaded', function() {
    document.addEventListener('click', function(e) {
        // Buscamos el botón con la clase que ya creamos
        const boton = e.target.closest('.btn-mapa-dinamico');
        
        if (boton) {
            let info = boton.getAttribute('data-coords');
            
            if (info) {
                // Si el usuario pegó un link completo, extraemos la ubicación
                if (info.includes('google.com/maps')) {
                    // Intentamos sacar las coordenadas o el nombre del lugar del link
                    const match = info.match(/q=([^&]+)/) || info.match(/place\/([^/]+)/);
                    if (match) {
                        info = match[1];
                    }
                }
                
                setTimeout(() => {
                    const iframe = document.querySelector('#mapa-dinamico iframe');
                    if (iframe) {
                        // Construimos la URL limpia para el mapa
                        const nuevaUrl = `https://maps.google.com/maps?q=${info}&t=m&z=16&output=embed`;
                        iframe.src = nuevaUrl;
                    }
                }, 500);
            }
        }
    });
});
</script>
<script>
document.addEventListener('DOMContentLoaded', function() {
    // 1. Verificación para el editor de Elementor
    if (document.body.classList.contains('elementor-editor-active')) return;

    // 2. Definición de nuevas IDs y Clases
    const UI = {
        botonEntrar: document.querySelector('.v2-boton-entrar'),
        seccionBloqueo: document.getElementById('v2-capa-bloqueo'),
        musica: document.getElementById('v2-musica'),
        botonMusica: document.getElementById('v2-boton-control')
    };

    // 3. Inicialización: Si existen los elementos, bloqueamos el scroll
    if (UI.botonEntrar && UI.seccionBloqueo) {
        document.body.style.overflow = 'hidden';

        // 4. Acción al hacer clic en "Entrar"
        UI.botonEntrar.addEventListener('click', function(e) {
            e.preventDefault();

            // --- A. ACTIVAR PANTALLA COMPLETA ---
            const docElm = document.documentElement;
            const entrarFS = docElm.requestFullscreen || 
                             docElm.webkitRequestFullscreen || 
                             docElm.msRequestFullscreen || 
                             docElm.mozRequestFullScreen;

            if (entrarFS) {
                entrarFS.call(docElm).catch(err => console.warn("FS denegado:", err.message));
            }

            // --- B. MÚSICA Y VISIBILIDAD DE CONTROL ---
            if (UI.musica) {
                UI.musica.play().catch(err => console.log("Reproducción bloqueada por navegador"));
            }
            if (UI.botonMusica) {
                UI.botonMusica.style.display = 'flex';
                setTimeout(() => { UI.botonMusica.style.opacity = '1'; }, 100);
            }

            // --- C. ACTIVAR ANIMACIÓN DEL SOBRE (CSS Clase .v2-abrir) ---
            UI.seccionBloqueo.classList.add('v2-abrir');

            // --- D. LIMPIEZA Y RETORNO DE SCROLL ---
            setTimeout(() => {
                document.body.style.overflow = 'auto';
            }, 1000);

            setTimeout(() => {
                UI.seccionBloqueo.style.display = 'none';
            }, 1500);
        });
    }

    // 5. CONTROL PLAY/PAUSE (Independiente)
    if (UI.botonMusica && UI.musica) {
        UI.botonMusica.addEventListener('click', function(e) {
            // Evita que el clic se pierda en los elementos internos (SVG u ondas)
            e.stopPropagation(); 

            if (UI.musica.paused) {
                UI.musica.play();
                UI.botonMusica.classList.remove('paused');
                console.log("Música iniciada");
            } else {
                UI.musica.pause();
                UI.botonMusica.classList.add('paused');
                console.log("Música pausada");
            }
        });
    }
});
</script>
	</body>
</html>


