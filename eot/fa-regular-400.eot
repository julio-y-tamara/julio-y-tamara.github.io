<style>
/* Estado base */
.zoom-animar {
  opacity: 0;
  transform: scale(0.8);
  transition: transform 0.8s cubic-bezier(0.25, 0.46, 0.45, 0.94), opacity 0.8s ease;
  will-change: transform, opacity; /* Optimiza el uso de la tarjeta gráfica */
}

/* Animación de entrada */
.zoom-animar.zoom-in {
  opacity: 1;
  transform: scale(1);
}

/* Animación de salida (opcional) */
.zoom-animar.zoom-out {
  opacity: 0;
  transform: scale(0.8);
}

/* Visualización en el editor para que no desaparezca mientras trabajas */
.elementor-editor-active .zoom-animar {
  opacity: 1 !important;
  transform: none !important;
}
</style>
<style>
:root {
  -color-boda: #656F52; /* Color por defecto */
}

/* Contenedor principal del botón */
.music-btn-container {
  position: fixed;
  bottom: 30px;
  right: 30px;
  width: 60px;
  height: 60px;
  display: none; /* Se activa con el click de Ingresar */
  justify-content: center;
  align-items: center;
  z-index: 9999;
  cursor: pointer;
}

/* Caja del icono (Efecto Cristal) */
.music-icon-box {
  position: relative;
  width: 100%;
  height: 100%;
  background: color-mix(in srgb, var(--color-boda) 40%, transparent);
  backdrop-filter: blur(8px);
  -webkit-backdrop-filter: blur(8px);
  border: 1px solid rgba(255, 255, 255, 0.2);
  border-radius: 50%;
  display: flex;
  justify-content: center;
  align-items: center;
  z-index: 2;
  transition: all 0.3s ease;
}

/* Icono SVG */
#iconoMusica {
  width: 28px;
  height: 28px;
  animation: musicBounce 2s infinite ease-in-out;
}
#iconoMusica path { fill: #FFFFFF; }

/* Anillo de pulsación (Ondas hacia los costados) */
.pulse-ring {
  position: absolute;
  width: 100%;
  height: 100%;
  background: color-mix(in srgb, var(--color-boda) 30%, transparent);
  border-radius: 50%;
  z-index: 1;
  animation: pulseExpand 2s infinite;
}

/* Animaciones */
@keyframes musicBounce {
  0%, 100% { transform: translateY(0) rotate(-5deg); }
  50% { transform: translateY(-5px) rotate(5deg); }
}

@keyframes pulseExpand {
  0% { transform: scale(1); opacity: 0.8; }
  100% { transform: scale(2.2); opacity: 0; }
}

/* Estado cuando se pausa */
.music-btn-container.paused .pulse-ring { animation-play-state: paused; opacity: 0; }
.music-btn-container.paused .music-icon-box { background: rgba(0,0,0,0.3); }
</style>
<style>
/* 1. IMPRESIÓN CAPA DE BLOQUEO */
body:not(.elementor-editor-active) #v2-capa-bloqueo {
    position: fixed !important;
    top: 0; left: 0; width: 100vw; height: 100vh;
    z-index: 9999;
    transition: opacity 1.2s ease-in-out, visibility 1.2s !important;
}

/* Cuando se activa el JS, el fondo siempre se desvanece */
#v2-capa-bloqueo.v2-abrir {
    opacity: 0 !important;
    pointer-events: none !important;
    visibility: hidden;
}

/* 2. ANIMACIÓN CORTINAS
   Si la plantilla tiene columnas, estas se moverán.
   Si la plantilla no tiene estas clases, este código no hace nada. */
.v2-sobre-izq, .v2-sobre-der {
    transition: transform 1.2s cubic-bezier(0.4, 0, 0.2, 1) !important;
    will-change: transform;
}

#v2-capa-bloqueo.v2-abrir .v2-sobre-izq {
    transform: translateX(-100%) !important;
}

#v2-capa-bloqueo.v2-abrir .v2-sobre-der {
    transform: translateX(100%) !important;
}

/* 3. BOTÓN MÚSICA */

/* Fix de interacción música */
#v2-boton-control {
    pointer-events: auto !important;
    display: none; opacity: 0;
    transition: opacity 0.5s ease;
}

#v2-boton-control * { pointer-events: none !important; }

#v2-boton-control.paused { filter: grayscale(1); opacity: 0.6 !important; }

/* Contenedor principal del botón */
.v2-music-btn-container {
  position: fixed;
  bottom: 30px;
  right: 30px;
  width: 60px;
  height: 60px;
  display: none; /* Se activa con el click de Ingresar */
  justify-content: center;
  align-items: center;
  z-index: 9999;
  cursor: pointer;
}

/* Caja del icono (Efecto Cristal) */
.v2-music-icon-box {
  position: relative;
  width: 100%;
  height: 100%;
  background: color-mix(in srgb, var(--v2-color-boda) 40%, transparent);
  backdrop-filter: blur(8px);
  -webkit-backdrop-filter: blur(8px);
  border: 1px solid rgba(255, 255, 255, 0.2);
  border-radius: 50%;
  display: flex;
  justify-content: center;
  align-items: center;
  z-index: 2;
  transition: all 0.3s ease;
}

/* Icono SVG */
#v2-iconoMusica {
  width: 28px;
  height: 28px;
  animation: v2-musicBounce 2s infinite ease-in-out;
}

#v2-iconoMusica path { fill: #FFFFFF; }

/* Anillo de pulsación (Ondas hacia los costados) */
.v2-pulse-ring {
  position: absolute;
  width: 100%;
  height: 100%;
  background: color-mix(in srgb, var(--v2-color-boda) 30%, transparent);
  border-radius: 50%;
  z-index: 1;
  animation: v2-pulseExpand 2s infinite;
}

/* Animaciones */
@keyframes v2-musicBounce {
  0%, 100% { transform: translateY(0) rotate(-5deg); }
  50% { transform: translateY(-5px) rotate(5deg); }
}

@keyframes v2-pulseExpand {
  0% { transform: scale(1); opacity: 0.8; }
  100% { transform: scale(2.2); opacity: 0; }
}

/* Estado cuando se pausa */

.v2-music-btn-container.paused .v2-pulse-ring { animation-play-state: paused; opacity: 0; }
.v2-music-btn-container.paused .v2-music-icon-box { background: rgba(0,0,0,0.3); }

/* 4. ANIMACIÓN APARICIÓN INVITACIÓN */
.v2-aparecer {
    animation: v2-fadeInUp 0.8s forwards;
}
@keyframes v2-fadeInUp {
    from { opacity: 0; transform: translateY(20px); }
    to { opacity: 1; transform: translateY(0); }
}
</style>
<style type="text/css">
/* BOTÓN LATIDO SUAVE */

/* Efecto de Latido */
.boton-latido {
    display: inline-block; /* Asegura que el escalado funcione correctamente */
    animation: latido-suave 1.5s ease-in-out infinite;
    transition: all 0.3s ease;
}

/* Pausar el latido cuando el usuario pasa el mouse (opcional, se ve más profesional) */
.boton-latido:hover {
    animation-play-state: paused;
    transform: scale(1.05); /* Se queda un poquito más grande al apuntar */
}

@keyframes latido-suave {
    0% {
        transform: scale(1);
    }
    50% {
        transform: scale(1.05); /* Crece un 5% */
    }
    100% {
        transform: scale(1);
    }
}
</style>
<style>
.animar {
  opacity: 0;
  transform: translateY(30px);
  transition: all 1.5s ease-out;
}
.animar.in-view {
  opacity: 1;
  transform: translateY(0);
}

.elementor-editor-active .animar {
  opacity: 1 !important;
  transform: none !important;
}
</style>
<style>
/* Oculta cualquier elemento con la clase 'elemento-a-ocultar' */
/* SOLO si el body (cuerpo de la página) tiene la clase 'ocultar-cuerpo' */
.ocultar-cuerpo .elemento-a-ocultar {
    display: none !important;
}

/* Oculta el elemento 'clase-del-acto' */
/* SOLO si el body tiene la clase 'es-un-acto' */
.es-un-acto .clase-del-acto {
    display: none !important;
}
</style>
